[node name="Notes" type="TextEdit" parent="."]
layout_mode = 1
anchors_preset = -1
anchor_left = 0.005
anchor_top = 0.15
anchor_right = 0.18
anchor_bottom = 0.9
offset_right = 8.0
grow_vertical = 2
text = "Instructions:
- Click the game board to start.
- Use the arrow keys to move the
board, space to attack, enter to
roll and start the next turn.
- The game consists of 5 enemy dice
below the board. 1 die representing
health in the corner. 1 action die 
(initially) that you'll roll to
determine how many actions you
get in a turn.
- Each turn starts by rolling all
action dice. If any die is a 6, it may
not be used and you take 1 damage
for each enemy die you are
touching. If rolling multiple dice and
any form doubles, enemy dice not
under the board gain 1 health. If an
enemy exceeds 6 health in this way,
one of the action dice is returned as
a new enemy starting at 1 health.
- Any dice rolled that don't fall into
the above categories may be picked
and you get that many actions this 
turn.
- Actions include ascend, descend,
move left 1 space, move right 1
space, and attack.
- While ascended, you can't attack,
but enemies won't hit you either
- While descended, you may attack
the enemy at the 1 slot of the board
- Any non-6, non-double unused
action dice heal the enemy at the
indicated slot for 1 health. Then the
next turn begins.
- You win if all enemies are killed.
- You lose if your health drops
below 1."
placeholder_text = "Add any notes here..."
script = ExtResource("4_to0pj")

